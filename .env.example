# -------------------------------------------------------------------
# Vercel deployment — environment variables
# Copy this file to .env.local and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.
# -------------------------------------------------------------------

# Base path for the frontend (leave as "/" for a root deployment)
BASE_PATH=/

# ------------------------------------------------------------------
# API / database (required for the serverless API function)
# ------------------------------------------------------------------

# PostgreSQL connection string for the Drizzle ORM database pool.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ------------------------------------------------------------------
# Replit OIDC authentication (required for login/logout)
# ------------------------------------------------------------------

# Your Replit App ID — used as the OIDC client_id.
# Found in the Replit Secrets panel as REPL_ID, or in your app settings.
REPL_ID=

# OIDC issuer URL (default is https://replit.com/oidc — only override if needed)
# ISSUER_URL=https://replit.com/oidc

# ------------------------------------------------------------------
# Spotify integration (required for the song-search feature)
# ------------------------------------------------------------------

# Spotify Developer credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
