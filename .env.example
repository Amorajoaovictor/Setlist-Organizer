# -------------------------------------------------------------------
# Vercel deployment — environment variables
# Copy this file to .env.local and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.
# -------------------------------------------------------------------

# Base path for the frontend (leave as "/" for a root deployment)
BASE_PATH=/

# ------------------------------------------------------------------
# API / database (required for the serverless API function)
# ------------------------------------------------------------------

# PostgreSQL connection string for the Drizzle ORM database pool.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ------------------------------------------------------------------
# OIDC authentication (required for login/logout)
# Works with any OIDC-compliant provider: Google, Auth0, Keycloak, etc.
# ------------------------------------------------------------------

# OIDC client ID registered with your identity provider.
OIDC_CLIENT_ID=

# OIDC client secret (required for confidential clients such as Google OAuth).
# Leave empty for public PKCE-only clients.
OIDC_CLIENT_SECRET=

# OIDC issuer URL (the base URL of your identity provider).
# Examples:
#   Google:   https://accounts.google.com
#   Auth0:    https://your-tenant.auth0.com
#   Keycloak: https://your-host/realms/your-realm
OIDC_ISSUER_URL=

# ------------------------------------------------------------------
# Spotify integration (required for the song-search feature)
# ------------------------------------------------------------------

# Spotify Developer credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
