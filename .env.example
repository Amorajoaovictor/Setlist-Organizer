# -------------------------------------------------------------------
# Vercel deployment — environment variables
# Copy this file to .env.local and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.
# -------------------------------------------------------------------

# Base path for the frontend (leave as "/" for a root deployment)
BASE_PATH=/

# PostgreSQL connection used by Prisma.
DATABASE_URL=postgresql://neondb_owner:npg_v3xoHAspFjI2@ep-polished-mode-am3q0n7w-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Auth.js / NextAuth.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# Deezer public catalog search does not require credentials.

# Optional local Music Separator API backed by Spleeter.
# This must be a browser-callable endpoint with CORS enabled because audio goes
# directly from the browser to the separator API. Do not put private secrets in
# NEXT_PUBLIC_* variables; use only a public/dev token here if your API needs one.
NEXT_PUBLIC_MUSIC_SEPARATOR_API_URL=http://localhost:8000
NEXT_PUBLIC_MUSIC_SEPARATOR_API_KEY=
NEXT_PUBLIC_MUSIC_SEPARATOR_FILE_FIELD=file
NEXT_PUBLIC_MUSIC_SEPARATOR_STEMS_FIELD=stems
