# -------------------------------------------------------------------
# Vercel deployment — environment variables
# Copy this file to .env.local and fill in the values.
# On Vercel, set these in Project Settings → Environment Variables.
# -------------------------------------------------------------------

# Base path for the frontend (leave as "/" for a root deployment)
BASE_PATH=/

# URL of the API server (e.g. your Replit backend or Railway deployment)
# Used by the frontend to proxy API requests.
# Example: https://my-api.railway.app
VITE_API_URL=
