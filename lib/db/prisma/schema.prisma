generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setlist {
  id        Int           @id @default(autoincrement())
  name      String
  createdAt DateTime      @default(now()) @map("created_at")
  songs     SetlistSong[]

  @@map("setlists")
}

model SetlistSong {
  id         Int                 @id @default(autoincrement())
  setlistId  Int                 @map("setlist_id")
  position   Int                 @default(0)
  title      String
  artist     String
  durationMs Int                 @map("duration_ms")
  bpm        Int?
  deezerId   String?             @map("deezer_id")
  spotifyId  String?             @map("spotify_id")
  albumArt   String?             @map("album_art")
  setlist    Setlist             @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  lyrics     SetlistSongLyrics?

  @@map("setlist_songs")
}

model SetlistSongLyrics {
  id           Int         @id @default(autoincrement())
  songId       Int         @unique @map("song_id")
  source       String      @default("manual")
  lrclibId     Int?        @map("lrclib_id")
  plainLyrics  String      @default("") @map("plain_lyrics")
  syncedLyrics String?     @map("synced_lyrics")
  lines        Json        @default("[]")
  bpm          Int?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  song         SetlistSong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@map("setlist_song_lyrics")
}

model BpmPreset {
  id              Int      @id @default(autoincrement())
  name            String
  bpm             Int
  timeSignature   String   @default("4/4") @map("time_signature")
  accentFirstBeat Boolean  @default(true) @map("accent_first_beat")
  subdivision     Int      @default(1)
  soundStyle      String   @default("classic") @map("sound_style")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("bpm_presets")
}
